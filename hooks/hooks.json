{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start-bootstrap.js\""
          }
        ],
        "description": "Load previous context and detect package manager on new session",
        "id": "session:start"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start-plugin-sync.js\""
          }
        ],
        "description": "Auto-install or reinstall VCP artifacts when version changes or on first use",
        "id": "session:start:plugin-sync"
      }
    ]
  }
}
